# Tockr Raspberry Pi deployment — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to deployment/.env and fill in your values.
# Never commit deployment/.env to version control.
#
#   cp deployment/.env.example deployment/.env
#   nano deployment/.env
#
# Then start:
#   docker compose -f deployment/docker-compose.yml --env-file deployment/.env up -d

# ─── Cookie security (required for HTTPS) ────────────────────────────────────
# Cloudflare Tunnel serves Tockr over HTTPS (HTTPS at the browser, plain HTTP
# inside Docker). The browser requires Secure=true on cookies over HTTPS.
#
# Keep this as "true" for all Cloudflare Tunnel deployments.
# Only set to "false" if you are testing locally over plain HTTP with no tunnel.
TOCKR_COOKIE_SECURE=true

# ─── Admin bootstrap (used only on first start) ──────────────────────────────
# Email address for the initial administrator account. The password is
# auto-generated and stored in /srv/tockr/data/.admin_password.
# After first start, retrieve it with:
#   docker compose -f deployment/docker-compose.yml exec tockr cat /app/data/.admin_password
#
# Changing this after the database already has users has no effect.
TOCKR_ADMIN_EMAIL=admin@example.com

# ─── Regional settings ───────────────────────────────────────────────────────
# Default timezone applied to new workspaces and the seeded admin user.
# Use an IANA timezone name. Examples: UTC, Europe/London, America/New_York,
# Africa/Johannesburg, Australia/Sydney
TOCKR_DEFAULT_TIMEZONE=UTC

# Default billing currency code for new workspaces.
# Examples: USD, EUR, GBP, ZAR, AUD
TOCKR_DEFAULT_CURRENCY=USD

# Future time entry policy. Controls whether users can log time in the future.
# Options: allow | deny | end_of_day | end_of_week
TOCKR_FUTURE_TIME_POLICY=end_of_day

# ─── Two-factor authentication ────────────────────────────────────────────────
# Controls TOTP/authenticator app enforcement for all users.
# Options: disabled | optional | required
# When set to "required", users must configure an authenticator app before
# they can access the app. Recommended for public internet deployments.
TOCKR_TOTP_MODE=disabled
